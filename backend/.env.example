# ============================================================
# 智能 RAG 知识库 — 环境变量配置模板
# 使用前请复制此文件为 .env 并填入真实值：
#   cp .env.example .env
# ============================================================

# RAG API Key（用于接口鉴权，请务必修改为强密码）
RAG_API_KEY=rag-dev-key-change-me

# DeepSeek API Key（必需，请在 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API 基础地址（可选，默认官方地址）
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 嵌入模型（可选）
RAG_EMBEDDING_MODEL=deepseek-embedding

# 对话模型（可选）
RAG_LLM_MODEL=deepseek-chat

# ChromaDB 持久化目录（可选，默认 ./chroma_data）
CHROMA_PERSIST_DIR=./chroma_data

# 临时上传目录（可选，默认 /tmp/doc_uploads）
RAG_TEMP_UPLOAD_DIR=/tmp/doc_uploads
